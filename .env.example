# ENLACE - variables de entorno del frontend (Vite). Copia a .env y rellena.
# La API key web de Firebase NO es secreta (va en el bundle); la seguridad la
# dan las reglas Firestore + App Check, no esconder estas claves.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (reCAPTCHA Enterprise). Sin esta clave la app funciona, pero sin
# proteccion anti-abuso. En produccion Clase A es obligatoria (la escritura del
# invitado es superficie publica).
VITE_RECAPTCHA_SITE_KEY=
